{
  "name": "wechat-mimocode",
  "version": "1.0.0",
  "description": "Chat with MiMoCode from WeChat - a MiMoCode Skill that bridges personal WeChat to local MiMoCode",
  "type": "module",
  "bin": {
    "wechat-mimocode": "bin/wechat-mimocode.js"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/main.js",
    "run": "node dist/main.js start",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "setup": "node dist/main.js setup",
    "daemon": "node dist/main.js daemon",
    "visualize": "npx tsx src/tools/visualize-logs.ts"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["wechat", "mimocode", "opencode", "claude-code", "bridge", "chat", "skill"],
  "author": "MiMo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wechat-ggGitHub/wechat-claude-code.git"
  }
}
