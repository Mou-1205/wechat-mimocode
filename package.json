{
  "name": "wechat-mimocode",
  "version": "1.0.1",
  "description": "Chat with MiMoCode from WeChat - bridges personal WeChat to local MiMoCode CLI",
  "type": "module",
  "bin": {
    "wechat-mimocode": "bin/wechat-mimocode.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/main.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "wechat",
    "mimocode",
    "opencode",
    "claude-code",
    "bridge",
    "chat",
    "skill",
    "cli"
  ],
  "author": "MiMo",
  "license": "MIT",
  "homepage": "https://github.com/Mou-1205/wechat-mimocode",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mou-1205/wechat-mimocode.git"
  },
  "bugs": {
    "url": "https://github.com/Mou-1205/wechat-mimocode/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
